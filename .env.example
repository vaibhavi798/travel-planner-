# Copy this file to ".env" and fill in your real values.
# These are BACKEND-ONLY (no VITE_ prefix), so they are never bundled into the browser.

# Get a Gemini key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Your MongoDB Atlas connection string
MONGO_URI=your_mongodb_connection_string_here

# FRONTEND (VITE_ prefix = exposed to the browser, which is fine — it's just a URL).
# Leave unset for local dev (defaults to http://localhost:5001).
# In production, set this to your deployed backend URL, e.g.:
# VITE_API_URL=https://your-backend.onrender.com
VITE_API_URL=
